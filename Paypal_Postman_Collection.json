{
  "info": {
    "name": "PayPal Backend API",
    "description": "End-to-End testing collection for the PayPal Microservices.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "user_url", "value": "http://localhost:8081", "type": "string" },
    { "key": "wallet_url", "value": "http://localhost:8088", "type": "string" },
    { "key": "notification_url", "value": "http://localhost:8084", "type": "string" },
    { "key": "jwt_token", "value": "", "type": "string" },
    { "key": "user_1_id", "value": "1", "type": "string" },
    { "key": "user_2_id", "value": "2", "type": "string" }
  ],
  "item": [
    {
      "name": "1. User & Auth Service",
      "item": [
        {
          "name": "Signup User 1 (Sender)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{gateway_url}}/auth/signup", "host": [ "{{gateway_url}}" ], "path": [ "auth", "signup" ] },
            "body": { "mode": "raw", "raw": "{\n    \"name\": \"Alice (Sender)\",\n    \"email\": \"alice@example.com\",\n    \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Signup User 2 (Receiver)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{gateway_url}}/auth/signup", "host": [ "{{gateway_url}}" ], "path": [ "auth", "signup" ] },
            "body": { "mode": "raw", "raw": "{\n    \"name\": \"Bob (Receiver)\",\n    \"email\": \"bob@example.com\",\n    \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login User 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.token) { pm.collectionVariables.set(\"jwt_token\", res.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{gateway_url}}/auth/login", "host": [ "{{gateway_url}}" ], "path": [ "auth", "login" ] },
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"alice@example.com\",\n    \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Get All Users (Bypass Gateway)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{user_url}}/api/users/all", "host": [ "{{user_url}}" ], "path": [ "api", "users", "all" ] }
          }
        }
      ]
    },
    {
      "name": "2. Wallet Service",
      "item": [
        {
          "name": "Create Wallet User 1",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{wallet_url}}/api/v1/wallets/create", "host": [ "{{wallet_url}}" ], "path": [ "api", "v1", "wallets", "create" ] },
            "body": { "mode": "raw", "raw": "{\n    \"userId\": {{user_1_id}},\n    \"currency\": \"INR\"\n}" }
          }
        },
        {
          "name": "Create Wallet User 2",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{wallet_url}}/api/v1/wallets/create", "host": [ "{{wallet_url}}" ], "path": [ "api", "v1", "wallets", "create" ] },
            "body": { "mode": "raw", "raw": "{\n    \"userId\": {{user_2_id}},\n    \"currency\": \"INR\"\n}" }
          }
        },
        {
          "name": "Credit Wallet User 1",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{wallet_url}}/api/v1/wallets/credit", "host": [ "{{wallet_url}}" ], "path": [ "api", "v1", "wallets", "credit" ] },
            "body": { "mode": "raw", "raw": "{\n    \"userId\": {{user_1_id}},\n    \"currency\": \"INR\",\n    \"amount\": 1000\n}" }
          }
        },
        {
          "name": "Get Wallet User 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{wallet_url}}/api/v1/wallets/{{user_1_id}}", "host": [ "{{wallet_url}}" ], "path": [ "api", "v1", "wallets", "{{user_1_id}}" ] }
          }
        }
      ]
    },
    {
      "name": "3. Transaction Service",
      "item": [
        {
          "name": "Initiate Transfer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{gateway_url}}/api/transactions/create", "host": [ "{{gateway_url}}" ], "path": [ "api", "transactions", "create" ] },
            "body": { "mode": "raw", "raw": "{\n    \"senderId\": {{user_1_id}},\n    \"receiverId\": {{user_2_id}},\n    \"amount\": 300\n}" }
          }
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{gateway_url}}/api/transactions/all", "host": [ "{{gateway_url}}" ], "path": [ "api", "transactions", "all" ] }
          }
        }
      ]
    },
    {
      "name": "4. Notification Service",
      "item": [
        {
          "name": "Get Notifications User 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{notification_url}}/api/notify/{{user_1_id}}", "host": [ "{{notification_url}}" ], "path": [ "api", "notify", "{{user_1_id}}" ] }
          }
        }
      ]
    },
    {
      "name": "5. Reward Service",
      "item": [
        {
          "name": "Get Rewards User 1",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{gateway_url}}/api/rewards/user/{{user_1_id}}", "host": [ "{{gateway_url}}" ], "path": [ "api", "rewards", "user", "{{user_1_id}}" ] }
          }
        }
      ]
    }
  ]
}
